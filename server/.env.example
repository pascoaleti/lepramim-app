NODE_ENV=production
PORT=8080
TRUST_PROXY=1
RATE_LIMIT_PER_MINUTE=90

ANDROID_PACKAGE_NAME=com.lepramim.app
ALLOWED_PRODUCT_IDS=lepramim_plus_monthly,lepramim_plus_annual

# Use "file" em VPS com disco persistente. Use "firestore" em Google Cloud Run.
STORAGE_DRIVER=file
FIRESTORE_USAGE_COLLECTION=lepramim_free_usage
FIRESTORE_ENTITLEMENTS_COLLECTION=lepramim_entitlements

FREE_USAGE_STORE_PATH=./data/free-usage.json
FREE_USAGE_RETENTION_DAYS=45
FREE_SCREEN_READS_PER_DAY=12
FREE_IMAGE_READS_PER_DAY=3

# Escolha uma das opcoes da Google Play Developer API.
# Opcao 1: OAuth Android Publisher. Use em VPS quando chave de service account estiver bloqueada.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# Opcao 2: service account JSON, se a organizacao permitir chaves.
GOOGLE_APPLICATION_CREDENTIALS=/caminho/seguro/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Opcional para resumo com IA. Sem isso, usa resumo local.
# GEMINI_API_KEY=
